{
  "name": "one-click-news-search",
  "version": "1.0.0",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/one-click-news-search.exe"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/axios/**/*",
      "node_modules/cheerio/**/*",
      "node_modules/xlsx/**/*",
      "node_modules/dayjs/**/*",
      "node_modules/express/**/*"
    ],
    "scripts": [
      "server.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [],
  "author": "xianye.wu <wxy9@meitu.com>",
  "license": "ISC",
  "description": "One-click multi-site news search desktop app",
  "dependencies": {
    "axios": "^1.16.0",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "6.6.0"
  },
  "overrides": {
    "into-stream": "6.0.0"
  }
}
